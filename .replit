entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["unzipNLS"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[workflows]

[[workflows.workflow]]
name = "Run"
mode = "parallel"
author = 48335487

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bot/run.py"
