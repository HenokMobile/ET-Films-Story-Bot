entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "unzipNLS", "zlib"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python", "main.py"]
deploymentTarget = "vm"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]

[[ports]]
localPort = 8080
externalPort = 80
